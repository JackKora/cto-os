#!/usr/bin/env bash
# CTO OS pre-commit hook. Runs two checks when relevant files are staged:
#
#  1. validate_deps — enforces the required-dependency DAG across modules.
#     Runs whenever any modules/**/SKILL.md file is staged. Fast (sub-second
#     on ~20 modules); never skipped when scope matches.
#
#  2. skill-reviewer subagent — qualitative review of SKILL.md / CLAUDE.md
#     changes against tests/claude-review.md. Runs whenever any SKILL.md or
#     CLAUDE.md file is staged. Requires the `claude` CLI; skipped (with a
#     warning) if absent.
#
# Enabled by:  git config core.hooksPath hooks  (done by install.sh).
# Bypass (not recommended):  git commit --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

staged="$(git diff --cached --name-only --diff-filter=ACMR || true)"

# ---------- Check 1: validate_deps ----------

staged_skills="$(echo "$staged" | grep -E '^modules/[^/]+/SKILL\.md$' || true)"

if [[ -n "$staged_skills" ]]; then
  echo "pre-commit: running validate_deps.py (module SKILL.md changes detected)"
  if ! command -v uv >/dev/null 2>&1; then
    echo "pre-commit: uv not found on PATH; cannot run validate_deps. Install uv or bypass with --no-verify." >&2
    exit 1
  fi
  deps_output="$(cd "$REPO_ROOT" && uv run python scripts/validate_deps.py --args '{}' 2>&1)"
  deps_status=$?
  if [[ $deps_status -ne 0 ]]; then
    echo "pre-commit: validate_deps.py failed (exit $deps_status):" >&2
    echo "$deps_output" >&2
    exit 1
  fi
fi

# ---------- Check 2: skill-reviewer ----------

staged_reviewable="$(echo "$staged" | grep -E '(SKILL|CLAUDE)\.md$' || true)"

if [[ -z "$staged_reviewable" ]]; then
  exit 0
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "pre-commit: claude CLI not in PATH; skipping skill review" >&2
  exit 0
fi

echo "pre-commit: running skill-reviewer on:"
echo "$staged_reviewable" | sed 's/^/  /'

files_inline="$(echo "$staged_reviewable" | tr '\n' ' ')"

prompt="Use the skill-reviewer subagent to review these staged files against the checklist at tests/claude-review.md:

$files_inline

Return exactly what the subagent reports. The subagent must end with one final line: REVIEW: PASS or REVIEW: FAIL."

output="$(claude -p "$prompt" 2>&1)" || {
  echo "pre-commit: claude invocation failed" >&2
  echo "$output" >&2
  exit 1
}

echo "$output"

if echo "$output" | grep -qE '^REVIEW:[[:space:]]+PASS'; then
  exit 0
fi

echo "" >&2
echo "pre-commit: skill review reported issues. Fix the FAILs above or bypass with --no-verify." >&2
exit 1
